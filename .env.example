# =============================================================================
# .env.example — Variables de entorno requeridas
# COPIA este archivo a .env y rellena con tus valores reales
# NUNCA subas el archivo .env a Git (está en .gitignore)
# =============================================================================

# Cadena de conexión completa a PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://usuario:password@db:5432/inventario_ti

# Credenciales individuales (usadas por el servicio postgres en docker-compose)
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=inventario_ti

# Clave secreta para firmar tokens JWT (cambiar en producción)
SECRET_KEY=cambia_esto_en_produccion_por_una_clave_larga_y_aleatoria

# Nombre del usuario de Docker Hub (para el pipeline CI/CD)
DOCKER_HUB_USER=tu_usuario_docker_hub
